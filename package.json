{
  "name": "microsoft-presenter-plus",
  "version": "0.1.0",
  "description": "Node.js library for receiving button events from the Microsoft Presenter+ on Linux via hidraw.",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/matterlobby/microsoft-presenter-plus.git"
  },
  "homepage": "https://github.com/matterlobby/microsoft-presenter-plus#readme",
  "bugs": {
    "url": "https://github.com/matterlobby/microsoft-presenter-plus/issues"
  },
  "keywords": [
    "microsoft",
    "presenter",
    "hidraw",
    "linux",
    "node"
  ],
  "license": "MIT",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "README.md"
  ],
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build": "tsc",
    "prepublishOnly": "npm run build",
    "typecheck": "tsc --noEmit",
    "example:list": "npm run build && node dist/examples/listPresenters.js",
    "example:log": "npm run build && node dist/examples/logEvents.js",
    "example:open-by-path": "npm run build && node dist/examples/openByPath.js"
  },
  "devDependencies": {
    "@types/node": "^24.0.0",
    "typescript": "^5.8.0"
  }
}
